backend/agents/signal_extractor.py

import json

from services.llm import ask_llm


def extract_signals(text: str):
    prompt = f"""
    Analyze the following enterprise communication.

    Extract:
    - blockers
    - risks
    - opportunities
    - deadlines
    - urgent issues

    Return JSON array.

    TEXT:
    {text}
    """

    response = ask_llm(prompt)

    try:
        return json.loads(response)
    except:
        return {"raw": response}


